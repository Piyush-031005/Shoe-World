{
  "framework": "nextjs",
  "buildCommand": "cd shoe-world && npm install && npm run build",
  "outputDirectory": "shoe-world/.next",
  "installCommand": "cd shoe-world && npm install",
  "headers": [
    {
      "source": "/models/(.*).glb",
      "headers": [
        {
          "key": "Content-Type",
          "value": "model/gltf-binary"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}

